# SQL Server connection string (mssql+pyodbc dialect)
DATABASE_URL=mssql+pyodbc://username:password@localhost/DatabaseName?driver=ODBC+Driver+17+for+SQL+Server

# Azure AI Search endpoint URL
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net

# Azure AI Search admin key
AZURE_SEARCH_KEY=your-azure-search-admin-key

# Azure AI Search index name (default: breach-file-index)
AZURE_SEARCH_INDEX=breach-file-index

# Base path on disk where breach TEXT files are stored
FILE_BASE_PATH=C:/data/breach_files

# Active case name for filtering DLU records
CASE_NAME=Case-2024-001

# Database (Azure PostgreSQL)
DATABASE_URL=postgresql+psycopg2://your_user:your_password@your-server.postgres.database.azure.com:5432/your_db
POSTGRES_SERVER=your-server.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=breach-file-index
AZURE_SEARCH_INDEX_V3=breach-file-index-v3

# File paths
FILE_BASE_PATH=./data/TEXT
